# Copy this file to `.env` in the same folder and fill in your credentials.
# The .env file is loaded automatically on each run.
#
# Works with Gmail (default) and any other email provider.
# For non-Gmail providers, also add smtp_host/smtp_port/smtp_ssl
# to the email section in config.yaml (see CLAUDE.md Step 4).
#
# Gmail setup:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Create an app password labeled e.g. "Job Monitor"
#   4. Paste the 16-character password below (remove spaces if any)

GMAIL_ADDRESS=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
